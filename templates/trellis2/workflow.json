{
  "1": {
    "class_type": "LoadTrellis2Models",
    "inputs": {
      "resolution": "1024_cascade",
      "attn_backend": "flash_attn",
      "vram_mode": "cpu_offload"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": ""
    }
  },
  "4": {
    "class_type": "Trellis2GetConditioning",
    "inputs": {
      "model_config": ["1", 0],
      "image": ["2", 0],
      "mask": ["2", 1],
      "include_1024": true,
      "background_color": "black"
    }
  },
  "5": {
    "class_type": "Trellis2ImageToShape",
    "inputs": {
      "model_config": ["1", 0],
      "conditioning": ["4", 0],
      "seed": 0,
      "ss_guidance_strength": 7.5,
      "ss_sampling_steps": 12,
      "shape_guidance_strength": 7.5,
      "shape_sampling_steps": 12
    }
  },
  "6": {
    "class_type": "Trellis2ShapeToTexturedMesh",
    "inputs": {
      "model_config": ["1", 0],
      "conditioning": ["4", 0],
      "shape_result": ["5", 0],
      "seed": 0,
      "tex_guidance_strength": 7.5,
      "tex_sampling_steps": 12
    }
  },
  "7": {
    "class_type": "Trellis2RenderPreview",
    "inputs": {
      "trimesh": ["5", 1],
      "num_views": 8,
      "resolution": 512,
      "render_mode": "normal"
    }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "trellis2_preview",
      "images": ["7", 0]
    }
  }
}
