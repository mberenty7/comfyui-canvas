{
  "name": "Tileable Texture (IP Adapter)",
  "description": "Generate seamlessly tileable textures with IP Adapter style reference",
  "color": "#4a9eff",
  "inputs": [
    {
      "name": "reference",
      "label": "Style Reference",
      "target_node": "4",
      "target_field": "image"
    }
  ],
  "params": [
    {
      "name": "positive",
      "label": "Positive Prompt",
      "type": "prompt",
      "target_node": "6",
      "target_field": "text",
      "default": "seamless tileable texture, flat even lighting, top down orthographic view, material texture map"
    },
    {
      "name": "negative",
      "label": "Negative Prompt",
      "type": "prompt",
      "target_node": "7",
      "target_field": "text",
      "default": "3d render, perspective, vanishing point, scene, room, building, sky, person, text, watermark, artistic, painting, blurry, depth of field, objects, uniform color, monochrome, glossy, shiny, shadows"
    },
    {
      "name": "seed",
      "label": "Seed",
      "type": "seed",
      "target_node": "9",
      "target_field": "seed",
      "default": 42
    },
    {
      "name": "ipa_weight",
      "label": "IP Adapter Weight",
      "type": "slider",
      "target_node": "5",
      "target_field": "weight",
      "min": 0,
      "max": 1.5,
      "step": 0.05,
      "default": 0.7
    },
    {
      "name": "cfg",
      "label": "CFG Scale",
      "type": "slider",
      "target_node": "9",
      "target_field": "cfg",
      "min": 1,
      "max": 15,
      "step": 0.5,
      "default": 7.0
    },
    {
      "name": "steps",
      "label": "Steps",
      "type": "integer",
      "target_node": "9",
      "target_field": "steps",
      "min": 10,
      "max": 50,
      "default": 30
    },
    {
      "name": "checkpoint",
      "label": "Checkpoint",
      "type": "select",
      "target_node": "1",
      "target_field": "ckpt_name",
      "options": ["newrealityxl_pro.safetensors", "sd_xl_base_1.0.safetensors"],
      "default": "newrealityxl_pro.safetensors"
    }
  ]
}
