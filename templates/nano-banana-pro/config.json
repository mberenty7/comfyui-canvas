{
  "name": "Nano Banana Pro",
  "description": "Gemini Pro image generation (high quality, up to 4K)",
  "color": "#ea8600",
  "inputs": [
    {
      "name": "prompt",
      "type": "prompt",
      "label": "Prompt",
      "target_positive": { "node": "1", "field": "prompt" }
    },
    {
      "name": "reference",
      "type": "image",
      "label": "Reference Image",
      "target_node": "1",
      "target_field": "images",
      "optional": true
    }
  ],
  "params": [
    {
      "name": "aspect_ratio",
      "label": "Aspect Ratio",
      "type": "select",
      "options": ["auto", "1:1", "2:3", "3:2", "3:4", "4:3", "4:5", "5:4", "9:16", "16:9", "21:9"],
      "default": "1:1",
      "target_node": "1",
      "target_field": "aspect_ratio"
    },
    {
      "name": "resolution",
      "label": "Resolution",
      "type": "select",
      "options": ["1K", "2K", "4K"],
      "default": "1K",
      "target_node": "1",
      "target_field": "resolution"
    },
    {
      "name": "seed",
      "label": "Seed",
      "type": "seed",
      "default": 42,
      "target_node": "1",
      "target_field": "seed"
    }
  ]
}
