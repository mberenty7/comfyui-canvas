{
  "name": "IP Adapter Style Transfer",
  "description": "Generate styled images using a reference image for visual guidance",
  "color": "#e94560",
  "inputs": [
    {
      "name": "reference",
      "label": "Reference Image",
      "target_node": "4",
      "target_field": "image"
    }
  ],
  "params": [
    {
      "name": "positive",
      "label": "Positive Prompt",
      "type": "prompt",
      "target_node": "6",
      "target_field": "text",
      "default": "a stylized object, handpainted miniature, dull matte finish, hand-carved, floating against white background, centered, table top gaming miniature, isolated object, completely in focus, sharp detail"
    },
    {
      "name": "negative",
      "label": "Negative Prompt",
      "type": "prompt",
      "target_node": "7",
      "target_field": "text",
      "default": "3d render, realistic, glossy, shiny, blurry, text, watermark, background objects, multiple items, shadows, tiling, repeating pattern"
    },
    {
      "name": "seed",
      "label": "Seed",
      "type": "seed",
      "target_node": "9",
      "target_field": "seed",
      "default": 777
    },
    {
      "name": "ipa_weight",
      "label": "IP Adapter Weight",
      "type": "slider",
      "target_node": "5",
      "target_field": "weight",
      "min": 0,
      "max": 1.5,
      "step": 0.05,
      "default": 0.7
    },
    {
      "name": "style_boost",
      "label": "Style Boost",
      "type": "slider",
      "target_node": "5",
      "target_field": "style_boost",
      "min": 0,
      "max": 2,
      "step": 0.1,
      "default": 1.0
    },
    {
      "name": "embeds_scaling",
      "label": "Embeds Scaling",
      "type": "select",
      "target_node": "5",
      "target_field": "embeds_scaling",
      "options": ["V only", "K+V", "K+V w/ normalize", "K+mean(V) w/ normalize"],
      "default": "V only"
    },
    {
      "name": "cfg",
      "label": "CFG Scale",
      "type": "slider",
      "target_node": "9",
      "target_field": "cfg",
      "min": 1,
      "max": 15,
      "step": 0.5,
      "default": 7.0
    },
    {
      "name": "steps",
      "label": "Steps",
      "type": "integer",
      "target_node": "9",
      "target_field": "steps",
      "min": 10,
      "max": 50,
      "default": 30
    },
    {
      "name": "checkpoint",
      "label": "Checkpoint",
      "type": "select",
      "target_node": "1",
      "target_field": "ckpt_name",
      "options": ["newrealityxl_pro.safetensors", "sd_xl_base_1.0.safetensors"],
      "default": "newrealityxl_pro.safetensors"
    },
    {
      "name": "width",
      "label": "Width",
      "type": "integer",
      "target_node": "8",
      "target_field": "width",
      "min": 512,
      "max": 2048,
      "default": 896
    },
    {
      "name": "height",
      "label": "Height",
      "type": "integer",
      "target_node": "8",
      "target_field": "height",
      "min": 512,
      "max": 2048,
      "default": 1152
    }
  ]
}
