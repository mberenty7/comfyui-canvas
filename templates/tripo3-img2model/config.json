{
  "name": "Tripo 3.0 (Image → 3D)",
  "description": "Generate a textured 3D model from one or more images using Tripo 3.0",
  "color": "#00b894",
  "inputs": [
    {
      "name": "image1",
      "type": "image",
      "label": "Image 1 (Front)",
      "target_node": "2",
      "target_field": "image",
      "batch_group": "image",
      "batch_target_node": "1",
      "batch_target_field": "image"
    },
    {
      "name": "image2",
      "type": "image",
      "label": "Image 2 (Side)",
      "target_node": "3",
      "target_field": "image",
      "optional": true,
      "batch_group": "image",
      "batch_target_node": "1",
      "batch_target_field": "image"
    },
    {
      "name": "image3",
      "type": "image",
      "label": "Image 3 (Back)",
      "target_node": "4",
      "target_field": "image",
      "optional": true,
      "batch_group": "image",
      "batch_target_node": "1",
      "batch_target_field": "image"
    }
  ],
  "params": [
    {
      "name": "model_version",
      "label": "Model Version",
      "type": "select",
      "options": [
        "v3.0-20250812",
        "v2.5-20250123",
        "v2.0-20240919"
      ],
      "default": "v3.0-20250812",
      "target_node": "1",
      "target_field": "model_version"
    },
    {
      "name": "sub_category",
      "label": "Category",
      "type": "select",
      "options": [
        "person:person2cartoon",
        "person:person2realistic",
        "animal",
        "object",
        "scene"
      ],
      "default": "person:person2cartoon",
      "target_node": "1",
      "target_field": "sub_category"
    },
    {
      "name": "texture_quality",
      "label": "Texture Quality",
      "type": "select",
      "options": ["standard", "detailed"],
      "default": "detailed",
      "target_node": "1",
      "target_field": "texture_quality"
    },
    {
      "name": "geometry_quality",
      "label": "Geometry Quality",
      "type": "select",
      "options": ["standard", "detailed"],
      "default": "standard",
      "target_node": "1",
      "target_field": "geometry_quality"
    },
    {
      "name": "texture_alignment",
      "label": "Texture Alignment",
      "type": "select",
      "options": ["original_image", "geometry"],
      "default": "geometry",
      "target_node": "1",
      "target_field": "texture_alignment"
    },
    {
      "name": "orientation",
      "label": "Orientation",
      "type": "select",
      "options": ["default", "align_image"],
      "default": "default",
      "target_node": "1",
      "target_field": "orientation"
    },
    {
      "name": "pbr",
      "label": "PBR Textures",
      "type": "select",
      "options": ["true", "false"],
      "default": "true",
      "target_node": "1",
      "target_field": "pbr"
    },
    {
      "name": "face_limit",
      "label": "Face Limit (-1 = unlimited)",
      "type": "integer",
      "min": -1,
      "max": 500000,
      "default": -1,
      "target_node": "1",
      "target_field": "face_limit"
    },
    {
      "name": "model_seed",
      "label": "Model Seed",
      "type": "seed",
      "default": 42,
      "target_node": "1",
      "target_field": "model_seed"
    },
    {
      "name": "texture_seed",
      "label": "Texture Seed",
      "type": "seed",
      "default": 42,
      "target_node": "1",
      "target_field": "texture_seed"
    }
  ],
  "cost": {
    "credits": 50,
    "note": "Tripo API via ComfyUI tokens"
  }
}
