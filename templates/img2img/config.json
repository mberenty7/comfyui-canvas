{
  "name": "Image to Image",
  "description": "Transform an existing image guided by a text prompt",
  "color": "#ff9800",
  "inputs": [
    {
      "name": "image",
      "label": "Source Image",
      "target_node": "4",
      "target_field": "image"
    }
  ],
  "params": [
    {
      "name": "positive",
      "label": "Positive Prompt",
      "type": "prompt",
      "target_node": "2",
      "target_field": "text",
      "default": ""
    },
    {
      "name": "negative",
      "label": "Negative Prompt",
      "type": "prompt",
      "target_node": "3",
      "target_field": "text",
      "default": "blurry, low quality, watermark, text"
    },
    {
      "name": "seed",
      "label": "Seed",
      "type": "seed",
      "target_node": "6",
      "target_field": "seed",
      "default": 42
    },
    {
      "name": "denoise",
      "label": "Denoise Strength",
      "type": "slider",
      "target_node": "6",
      "target_field": "denoise",
      "min": 0,
      "max": 1,
      "step": 0.05,
      "default": 0.65
    },
    {
      "name": "steps",
      "label": "Steps",
      "type": "integer",
      "target_node": "6",
      "target_field": "steps",
      "min": 1,
      "max": 50,
      "default": 25
    },
    {
      "name": "cfg",
      "label": "CFG Scale",
      "type": "slider",
      "target_node": "6",
      "target_field": "cfg",
      "min": 1,
      "max": 15,
      "step": 0.5,
      "default": 7.0
    },
    {
      "name": "checkpoint",
      "label": "Checkpoint",
      "type": "select",
      "target_node": "1",
      "target_field": "ckpt_name",
      "options": ["newrealityxl_pro.safetensors", "sd_xl_base_1.0.safetensors"],
      "default": "newrealityxl_pro.safetensors"
    },
    {
      "name": "sampler",
      "label": "Sampler",
      "type": "select",
      "target_node": "6",
      "target_field": "sampler_name",
      "options": ["euler", "euler_ancestral", "dpmpp_2m", "dpmpp_2m_sde", "ddim"],
      "default": "euler"
    },
    {
      "name": "scheduler",
      "label": "Scheduler",
      "type": "select",
      "target_node": "6",
      "target_field": "scheduler",
      "options": ["normal", "karras", "sgm_uniform", "simple"],
      "default": "normal"
    }
  ]
}
