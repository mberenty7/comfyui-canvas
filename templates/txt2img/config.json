{
  "name": "Text to Image",
  "description": "Generate an image from a text prompt",
  "color": "#4a9eff",
  "inputs": [
    {
      "name": "prompt",
      "type": "prompt",
      "label": "Prompt",
      "target_positive": { "node": "2", "field": "text" },
      "target_negative": { "node": "3", "field": "text" }
    }
  ],
  "params": [
    {
      "name": "seed",
      "label": "Seed",
      "type": "seed",
      "target_node": "5",
      "target_field": "seed",
      "default": 42
    },
    {
      "name": "steps",
      "label": "Steps",
      "type": "integer",
      "target_node": "5",
      "target_field": "steps",
      "min": 1,
      "max": 50,
      "default": 25
    },
    {
      "name": "cfg",
      "label": "CFG Scale",
      "type": "slider",
      "target_node": "5",
      "target_field": "cfg",
      "min": 1,
      "max": 15,
      "step": 0.5,
      "default": 7.0
    },
    {
      "name": "width",
      "label": "Width",
      "type": "integer",
      "target_node": "4",
      "target_field": "width",
      "min": 512,
      "max": 2048,
      "default": 1024
    },
    {
      "name": "height",
      "label": "Height",
      "type": "integer",
      "target_node": "4",
      "target_field": "height",
      "min": 512,
      "max": 2048,
      "default": 1024
    },
    {
      "name": "checkpoint",
      "label": "Checkpoint",
      "type": "select",
      "target_node": "1",
      "target_field": "ckpt_name",
      "options": ["newrealityxl_pro.safetensors", "sd_xl_base_1.0.safetensors"],
      "default": "newrealityxl_pro.safetensors"
    },
    {
      "name": "sampler",
      "label": "Sampler",
      "type": "select",
      "target_node": "5",
      "target_field": "sampler_name",
      "options": ["euler", "euler_ancestral", "dpmpp_2m", "dpmpp_2m_sde", "ddim"],
      "default": "euler"
    },
    {
      "name": "scheduler",
      "label": "Scheduler",
      "type": "select",
      "target_node": "5",
      "target_field": "scheduler",
      "options": ["normal", "karras", "sgm_uniform", "simple"],
      "default": "normal"
    }
  ]
}
